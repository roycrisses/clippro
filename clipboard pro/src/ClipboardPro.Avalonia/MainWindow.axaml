<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClipboardPro.Avalonia"
        xmlns:converters="clr-namespace:ClipboardPro.Avalonia.Converters"
        xmlns:vm="clr-namespace:ClipboardPro.ViewModels;assembly=ClipboardPro.Core"
        xmlns:m="clr-namespace:ClipboardPro.Models;assembly=ClipboardPro.Core"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
        x:Class="ClipboardPro.Avalonia.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="ClipBoard Pro"
        Width="1000"
        Height="700"
        MinWidth="800"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        TransparencyLevelHint="Mica"
        Background="Transparent">

    <Window.Resources>
        <!-- Converters -->
        <converters:ClippingTypeToIconConverter x:Key="TypeToIconConverter"/>
        <converters:TimeAgoConverter x:Key="TimeAgoConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/> <!-- Custom Title Bar Height placeholder -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Bar Area (Handled by system chrome mostly, but we can add content if needed) -->
        <Panel Grid.Row="0" IsHitTestVisible="False" Background="Transparent"/>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" 
                    Background="#0A0A0A" 
                    BorderBrush="#1A1A1A" 
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Project Lock Status -->
                    <Border Grid.Row="0" 
                            Background="#1A1A1A" 
                            Padding="12" 
                            Margin="8"
                            CornerRadius="8"
                            IsVisible="{Binding LockedProject, Converter={StaticResource BoolToVisConverter}}">
                        <StackPanel>
                            <TextBlock Text="🔒 PROJECT LOCKED" 
                                       Foreground="#FF7A00" 
                                       FontWeight="Bold" 
                                       FontSize="10"/>
                            <TextBlock Text="{Binding LockedProject.Name}" 
                                       Foreground="White" 
                                       FontSize="14"
                                       Margin="0,4,0,0"/>
                            <Button Content="Unlock" 
                                    Margin="0,8,0,0"
                                    Click="UnlockProject_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Navigation -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8">
                            <!-- Main Navigation -->
                            <TextBlock Text="NAVIGATION" 
                                       Foreground="#666" 
                                       FontSize="11" 
                                       FontWeight="SemiBold"
                                       Margin="8,8,0,8"/>
                            
                            <Button x:Name="AllButton" 
                                    Content="📋  All Clips" 
                                    HorizontalAlignment="Stretch" 
                                    HorizontalContentAlignment="Left"
                                    Click="FilterAll_Click"/>
                            
                            <Button x:Name="FavoritesButton" 
                                    Content="⭐  Favorites" 
                                    HorizontalAlignment="Stretch" 
                                    HorizontalContentAlignment="Left"
                                    Margin="0,4,0,0"
                                    Click="FilterFavorites_Click"/>

                            <!-- Projects Section -->
                            <StackPanel Margin="0,16,0,0">
                                <Grid>
                                    <TextBlock Text="PROJECTS" 
                                               Foreground="#666" 
                                               FontSize="11" 
                                               FontWeight="SemiBold"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"/>
                                    <Button Content="+" 
                                            HorizontalAlignment="Right"
                                            Width="28" Height="28"
                                            Click="AddProject_Click"/>
                                </Grid>
                                
                                <ItemsControl x:Name="ProjectsList" 
                                              ItemsSource="{Binding Projects}"
                                              Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="m:Project">
                                            <Button HorizontalAlignment="Stretch" 
                                                    HorizontalContentAlignment="Left"
                                                    Margin="0,2,0,0"
                                                    Tag="{Binding Id}"
                                                    Click="FilterProject_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" 
                                                             Fill="{Binding Color}" 
                                                             Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Name}"/>
                                                    <TextBlock Text="🔒" 
                                                               Margin="8,0,0,0"
                                                               IsVisible="{Binding IsLocked, Converter={StaticResource BoolToVisConverter}}"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Source Apps Section -->
                            <StackPanel Margin="0,16,0,0">
                                <TextBlock Text="BY APP" 
                                           Foreground="#666" 
                                           FontSize="11" 
                                           FontWeight="SemiBold"
                                           Margin="8,0,0,8"/>
                                
                                <ItemsControl x:Name="AppsList" 
                                              ItemsSource="{Binding SourceApps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Button HorizontalAlignment="Stretch" 
                                                    HorizontalContentAlignment="Left"
                                                    Margin="0,2,0,0"
                                                    Tag="{Binding}"
                                                    Click="FilterApp_Click">
                                                <TextBlock Text="{Binding}"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Stats Footer -->
                    <Border Grid.Row="2" Background="#0F0F0F" Padding="12">
                        <TextBlock x:Name="StatsText" 
                                   Text="0 clips" 
                                   Foreground="#666" 
                                   FontSize="12"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" Background="#050505">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar -->
                <Border Grid.Row="0" 
                        Background="#0A0A0A" 
                        Padding="16"
                        BorderBrush="#1A1A1A"
                        BorderThickness="0,0,0,1">
                    <TextBox x:Name="SearchBox"
                             Watermark="🔍 Search clips..."
                             Text="{Binding SearchQuery}"
                             FontSize="14"/>
                </Border>

                <!-- Shortcut Hint Watermark -->
                <StackPanel Grid.Row="1" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            Opacity="0.4"
                            IsHitTestVisible="False"
                            ZIndex="0">
                    <TextBlock Text="Global Shortcut" 
                               Foreground="#888" 
                               FontSize="14" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,16"
                               FontWeight="Medium"/>
                    <StackPanel Orientation="Horizontal">
                        <!-- Win Key -->
                        <Border Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="❖" FontFamily="Segoe MDL2 Assets" Foreground="White" Margin="0,1,8,0" FontSize="14"/>
                                <TextBlock Text="Cmd" Foreground="White" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </Border>
                        
                        <TextBlock Text="+" Foreground="#555" VerticalAlignment="Center" Margin="4" FontSize="18" FontWeight="Light"/>
                        
                        <!-- Shift Key -->
                        <Border Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="4">
                            <TextBlock Text="Shift" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        </Border>
                        
                        <TextBlock Text="+" Foreground="#555" VerticalAlignment="Center" Margin="4" FontSize="18" FontWeight="Light"/>
                        
                        <!-- C Key -->
                        <Border Background="#222" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="16,8" Margin="4">
                            <TextBlock Text="C" Foreground="#FF7A00" FontWeight="Bold" FontSize="16"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Clippings Grid -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              Padding="16">
                    <ItemsControl x:Name="ClippingsGrid" 
                                  ItemsSource="{Binding Clippings}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="m:Clipping">
                                <Border Background="#1A1A1A" 
                                        BorderBrush="#2A2A2A" 
                                        BorderThickness="1"
                                        CornerRadius="8" 
                                        Width="280"
                                        Margin="0,0,12,12"
                                        Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Header -->
                                        <Grid Grid.Row="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Type, Converter={StaticResource TypeToIconConverter}}" 
                                                           FontSize="14"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding SourceApp}" 
                                                           Foreground="#888" 
                                                           FontSize="12"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" 
                                                        HorizontalAlignment="Right">
                                                <Button Padding="4"
                                                        Tag="{Binding}"
                                                        Click="ToggleFavorite_Click"
                                                        ToolTip.Tip="Toggle Favorite">
                                                    <TextBlock Text="{Binding IsFavorite, Converter={StaticResource BoolToVisConverter}, ConverterParameter=star}"/>
                                                </Button>
                                                <Button Padding="4"
                                                        Margin="4,0,0,0"
                                                        Tag="{Binding}"
                                                        Click="CopyClipping_Click"
                                                        ToolTip.Tip="Copy to Clipboard">
                                                    <TextBlock Text="📋"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Content Preview -->
                                        <TextBlock Grid.Row="1" 
                                                   Text="{Binding Preview}" 
                                                   Foreground="#EEE"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="80"
                                                   Margin="0,8,0,8"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- Footer -->
                                        <Grid Grid.Row="2">
                                            <TextBlock Text="{Binding Timestamp, Converter={StaticResource TimeAgoConverter}}" 
                                                       Foreground="#666" 
                                                       FontSize="11"/>
                                            <Button Content="🗑️" 
                                                    HorizontalAlignment="Right"
                                                    Padding="4"
                                                    Tag="{Binding}"
                                                    Click="DeleteClipping_Click"
                                                    ToolTip.Tip="Delete"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
