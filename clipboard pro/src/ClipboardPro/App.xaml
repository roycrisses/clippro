<Application x:Class="ClipboardPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Styles -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="#1A1A1A"/>
                <Setter Property="BorderBrush" Value="#2A2A2A"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="12"/>
            </Style>

            <!-- Accent Colors -->
            <SolidColorBrush x:Key="AccentBrush" Color="#FF7A00"/>
            <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF9A33"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#0A0A0A"/>
            <SolidColorBrush x:Key="CardBrush" Color="#1A1A1A"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#2A2A2A"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#888888"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
